@prefix pm:      <https://pajew-ski.github.io/prima-materia/ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#
# prima-materia — consciousness states (AwarenessContext instances)
#
# Māṇḍūkya Upaniṣad supplies Jāgrat / Svapna / Suṣupti / Turīya.
# Gnostic and Scholarly states extend this for operative-vs-philological
# epistemic tagging.
#

pm:WakingState a pm:AwarenessContext ;
    rdfs:label "Waking state (Jāgrat)"@en, "Wachzustand (Jāgrat)"@de ;
    skos:definition "Ordinary outward-turned awareness of gross objects."@en ;
    dcterms:source "Māṇḍūkya Upaniṣad, verse 3" .

pm:DreamingState a pm:AwarenessContext ;
    rdfs:label "Dreaming state (Svapna)"@en, "Traumzustand (Svapna)"@de ;
    skos:definition "Inward-turned awareness of subtle objects generated by the mind."@en ;
    dcterms:source "Māṇḍūkya Upaniṣad, verse 4" .

pm:DeepSleepState a pm:AwarenessContext ;
    rdfs:label "Deep sleep state (Suṣupti)"@en, "Tiefschlafzustand (Suṣupti)"@de ;
    skos:definition "Undifferentiated awareness in which no object is apprehended."@en ;
    dcterms:source "Māṇḍūkya Upaniṣad, verse 5" .

pm:TranscendentState a pm:AwarenessContext ;
    rdfs:label "Transcendent state (Turīya)"@en, "Transzendenter Zustand (Turīya)"@de ;
    skos:definition "The fourth state: pure awareness that is neither outward- nor inward-turned, and not a negation of either."@en ;
    dcterms:source "Māṇḍūkya Upaniṣad, verse 7" .

pm:GnosticState a pm:AwarenessContext ;
    rdfs:label "Gnostic state"@en, "Gnostischer Zustand"@de ;
    skos:definition "Operative consciousness in which an assertion is made from direct insight rather than from historical reconstruction."@en ;
    skos:note "Use this context when a triple expresses a claim from within a tradition's first-person perspective."@en .

pm:ScholarlyState a pm:AwarenessContext ;
    rdfs:label "Scholarly state"@en, "Wissenschaftlicher Zustand"@de ;
    skos:definition "Philological and historical mode of assertion: claims are reports about what a tradition holds, not claims made from within it."@en ;
    skos:note "Default context for tradition files in Phase 1."@en .
